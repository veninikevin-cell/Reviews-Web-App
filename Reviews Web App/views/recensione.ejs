<!DOCTYPE html>
<html>
<head>
    <title><%= review.product_name %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div style="max-width:700px; margin:30px auto; padding:0 20px;">

    <a href="/" style="color:#888; font-size:0.9rem;">← Torna indietro</a>

    <div class="card" style="margin-top:15px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <a href="/oggetto/<%= encodeURIComponent(review.product_name) %>" style="text-decoration:none;">
                <h1 style="color:#4a90e2;"><%= review.product_name %></h1>
            </a>
            <span style="font-size:1.5rem; font-weight:bold;">⭐ <%= review.rating %>/10</span>
        </div>
        <p style="color:#888; margin-top:5px;">📂 <%= review.tipo %></p>
        <p style="margin-top:5px;">👤 <%= review.user_username %></p>
    </div>

    <div class="card">
        <p style="line-height:1.7; color:#444;"><%= review.comment %></p>
    </div>

</div>

</body>
</html>