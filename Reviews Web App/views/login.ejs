<%pageTitle = "Login" %>

<!DOCTYPE html>
<html><head>
    <title>Recensioni</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<div style="max-width:420px;margin:4rem auto;">
    <div style="text-align:center;margin-bottom:2rem;">
        <div style="font-size:3rem;margin-bottom:0.5rem;">🔐</div>
        <h1>Bentornato!</h1>
        <p>Accedi al tuo account per continuare</p>
    </div>

    <div class="form-box" style="max-width:100%">
        <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
        <form action="/login" method="POST">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="Username" required autofocus>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn-primary" style="width:100%;margin-top:1rem;">Accedi</button>
        </form>

        <p style="text-align:center;margin-top:1.2rem;font-size:0.88rem;">
            Non hai un account? <a href="/register">Registrati</a>
        </p>
    </div>
</div>
    </div>
    </body>
    </html>