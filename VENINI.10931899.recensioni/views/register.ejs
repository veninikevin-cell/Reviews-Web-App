<!DOCTYPE html>
<html>
<head>
    <title>Registrati</title>
<link rel="stylesheet" href="/style.css"></head>
<body>
<div class="card">
    <div class="card">
        <h1>Crea il tuo account</h1>
        <p>La tua app di liste e recensioni</p>
    </div>

    <div class="form-box" style="max-width:100%;">
        <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

        <form action="/register" method="POST">
            <div class="card">
                <div class="form-group">
                    <label>Username *</label>
                    <input type="text" name="username" placeholder="username" required>
                </div>
                <div class="form-group">
                    <label>Nome *</label>
                    <input type="text" name="nome" placeholder="Nome" required>
                </div>
                <div class="form-group">
                    <label>Cognome *</label>
                    <input type="text" name="cognome" placeholder="Cognome" required>
                </div>
            </div>

            <div class="card">
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" name="email" placeholder="example@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password * <span style="font-size:0.7rem;color:var(--text-muted);font-weight:400;">(min. 8 caratteri)</span></label>
                    <input type="password" name="password" placeholder="••••••••" required minlength="8">
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;padding:0.8rem;font-size:0.9rem;">Crea account</button>
        </form>

        <p style="text-align:center;margin-top:1.2rem;font-size:0.88rem;">
            Hai già un account? <a href="/login">Accedi</a>
        </p>
    </div>
</div>
</body>
</html>